---
const widgetSrc = import.meta.env.DEV ? 'http://localhost:3001/widget/aiembed.js' : '/aiembed.js';
const widgetApiUrl = import.meta.env.DEV ? 'http://localhost:3001/aiembed' : 'https://api.kubeshark.com/aiembed';
---

<div data-aiembed-inline></div>
<div id="ai-chat" style="max-width: 800px; margin: 20px 0;"></div>

<script is:inline define:vars={{ widgetSrc, widgetApiUrl }}>
  (function() {
    var s = document.createElement('script');
    s.src = widgetSrc;
    s.setAttribute('data-agent', 'docs-agent');
    s.setAttribute('data-api-url', widgetApiUrl);
    s.setAttribute('data-mode', 'inline');
    document.getElementById('ai-chat').appendChild(s);
  })();
</script>
